---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div id="particles-container" class={`particles-container ${className}`}>
  <canvas id="particles-canvas"></canvas>
</div>

<script>
  import('./particles-client.js');
</script>

<style>
  .particles-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    pointer-events: none;
    z-index: 10;
    overflow: hidden;
  }

  #particles-canvas {
    width: 100%;
    height: 100%;
    opacity: 0.8;
    z-index: 10; /* Make sure particles are above hero background */
    display: block;
  }

  /* Ensure particles work with different screen sizes */
  @media (max-width: 768px) {
    .particles-container {
      opacity: 0.6; /* Reduce intensity on mobile for performance */
    }
  }

  /* Dark mode adjustments */
  :global(.dark) .particles-container {
    filter: brightness(1.1);
  }

  :global(:not(.dark)) .particles-container {
    filter: brightness(0.9);
  }
</style>