---
// Tabbed interface container
---

<div class="dockit-tabs-container">
	<div class="dockit-tabs-items" style="display: none;">
		<slot />
	</div>
	<div class="dockit-tabs-nav"></div>
	<div class="dockit-tabs-content"></div>
</div>

<style>
	.dockit-tabs-nav {
		border-top: 2px solid var(--sl-color-gray-6, rgba(255, 255, 255, 0.1));
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	@media (min-width: 768px) {
		.dockit-tabs-nav {
			flex-direction: row;
			justify-content: center;
			align-items: stretch;
		}
	}

	.dockit-tabs-content {
		position: relative;
		overflow: hidden;
		background-color: rgba(21, 21, 21, 0.5);
		margin-top: 3.5rem;
		padding: 0.6rem;
		border-radius: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.1);
		min-height: 400px;
	}

	:global(:not(.dark)) .dockit-tabs-content {
		background-color: rgba(247, 247, 247, 0.5);
		border-color: rgba(0, 0, 0, 0.1);
	}

	@media (max-width: 767px) {
		.dockit-tabs-content {
			min-height: 300px;
		}
	}

	@media (max-width: 560px) {
		.dockit-tabs-content {
			min-height: auto;
		}
	}
</style>

<script>
	function initDockitTabs() {
		// Inject CSS only once
		if (!document.getElementById('dockit-tabs-styles')) {
			const style = document.createElement('style');
			style.id = 'dockit-tabs-styles';
			style.textContent = `
				.dockit-tabs-nav .dockit-tab-nav {
					flex: 1;
					transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
					overflow: hidden;
					margin: 0 !important;
					opacity: 0.6;
				}

				.dockit-tabs-nav .dockit-tab-nav[data-active="true"] {
					transform: translateY(-2px);
					opacity: 1;
				}

				.dockit-tabs-nav .tab-button {
					width: 100%;
					border: none;
					padding: 1.5rem 1rem;
					color: var(--sl-color-white, #f6f6f6);
					background: transparent;
					cursor: pointer;
					display: flex;
					gap: 1rem;
					transition: all 0.3s ease;
					position: relative;
					overflow: hidden;
					align-items: center;
				}

				:global(:not(.dark)) .dockit-tabs-nav .tab-button {
					color: #181818;
				}

				.dockit-tabs-nav .tab-button:hover {
					background: rgba(255, 255, 255, 0.05);
				}

				:global(:not(.dark)) .dockit-tabs-nav .tab-button:hover {
					background: rgba(0, 0, 0, 0.05);
				}

				.dockit-tabs-nav .dockit-tab-nav[data-active="true"] .tab-button::before {
					content: "";
					position: absolute;
					top: 0;
					left: 0;
					right: 0;
					height: 2px;
					background: linear-gradient(35.65deg, #3a1c71 -10.94%, #D76D77 61.04%, #ffca7b 133.01%);
				}

				.dockit-tabs-nav .tab-number {
					font-size: 1.1rem;
					background: var(--dockit-gradient, linear-gradient(35.65deg, #3a1c71 -10.94%, #D76D77 61.04%, #ffca7b 133.01%));
					color: white;
					width: 2.5rem;
					height: 2.5rem;
					border-radius: 50%;
					display: flex;
					align-items: center;
					justify-content: center;
					flex-shrink: 0;
					transition: all 0.3s ease;
					font-weight: 600;
				}

				.dockit-tabs-nav .tab-content {
					text-align: left;
					flex-grow: 1;
				}

				.dockit-tabs-nav .tab-title {
					font-size: 1.25rem;
					font-weight: 600;
					margin: 0 0 0.5rem 0;
					transition: all 0.3s ease;
				}

				.dockit-tabs-nav .tab-subtitle {
					font-size: 0.875rem;
					opacity: 0.8;
					margin: 0;
					line-height: 1.4;
					transition: all 0.3s ease;
					color: var(--aw-color-text-muted);
				}

				.dockit-tabs-content .dockit-tab-content {
					width: 100%;
					height: 100%;
					display: none;
					align-items: center;
					justify-content: center;
					padding: 2rem;
					transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
					margin-top: 0;
				}

				.dockit-tabs-content .dockit-tab-content[data-active="true"] {
					display: flex !important;
				}

				.dockit-tabs-content .tab-text-content {
					width: 100%;
				}

				@media (max-width: 767px) {
					.dockit-tabs-nav .tab-button { padding: 1rem; }
					.dockit-tabs-nav .tab-number { font-size: 1rem; width: 2rem; height: 2rem; }
					.dockit-tabs-nav .tab-title { font-size: 1.125rem; }
					.dockit-tabs-nav .tab-subtitle { font-size: 0.8rem; }
					.dockit-tabs-content .dockit-tab-content { padding: 1rem; }
				}
			`;
			document.head.appendChild(style);
		}

		// Initialize all tab containers
		const containers = document.querySelectorAll('.dockit-tabs-container');

		containers.forEach((container) => {
			const tabsItemsContainer = container.querySelector('.dockit-tabs-items');
			const tabsNavContainer = container.querySelector('.dockit-tabs-nav');
			const tabsContentContainer = container.querySelector('.dockit-tabs-content');

			if (!tabsItemsContainer || !tabsNavContainer || !tabsContentContainer) return;

			// Skip if already initialized
			if (tabsNavContainer.children.length > 0) return;

			const tabItems = tabsItemsContainer.querySelectorAll('.dockit-tab-item');
			if (tabItems.length === 0) return;

			let activeTabNumber = 1;

			// Setup tabs
			tabItems.forEach((item, index) => {
				const navElement = item.querySelector('.dockit-tab-nav');
				const contentElement = item.querySelector('.dockit-tab-content');

				if (navElement && contentElement) {
					const navClone = navElement.cloneNode(true);
					const contentClone = contentElement.cloneNode(true);

					const isActive = index === 0;
					navClone.setAttribute('data-active', isActive.toString());
					contentClone.setAttribute('data-active', isActive.toString());

					tabsNavContainer.appendChild(navClone);
					tabsContentContainer.appendChild(contentClone);
				}
			});

			// Bind events
			const tabButtons = tabsNavContainer.querySelectorAll('.tab-button');
			tabButtons.forEach((button) => {
				button.addEventListener('click', (e) => {
					e.preventDefault();
					const tabNumber = parseInt(button.dataset.tab || '1');

					if (tabNumber === activeTabNumber) return;

					// Deactivate all tabs
					tabsNavContainer.querySelectorAll('.dockit-tab-nav').forEach((nav) => {
						nav.setAttribute('data-active', 'false');
					});

					tabsContentContainer.querySelectorAll('.dockit-tab-content').forEach((content) => {
						content.setAttribute('data-active', 'false');
						content.style.display = 'none';
					});

					// Activate selected tab
					const targetNav = tabsNavContainer
						.querySelector(`[data-tab="${tabNumber}"]`)
						?.closest('.dockit-tab-nav');
					if (targetNav) {
						targetNav.setAttribute('data-active', 'true');
					}

					const targetContent = tabsContentContainer.querySelector(
						`[data-panel="${tabNumber}"]`
					);
					if (targetContent) {
						targetContent.style.display = 'flex';
						targetContent.setAttribute('data-active', 'true');
					}

					activeTabNumber = tabNumber;
				});
			});
		});
	}

	// Initialize on load
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initDockitTabs);
	} else {
		initDockitTabs();
	}

	// Re-initialize on page show (handles bfcache)
	window.addEventListener('pageshow', () => {
		initDockitTabs();
	});

	// Re-initialize after Astro page transitions (if enabled in the future)
	document.addEventListener('astro:page-load', () => {
		initDockitTabs();
	});
</script>
