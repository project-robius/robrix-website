---
import '@fontsource-variable/inter';
import '@fontsource/space-grotesk';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Space Grotesk', 'Inter Variable';

    /* Robrix Brand Colors - Orange and Deep Purple inspired by Rust + Matrix */
    --aw-color-primary: rgb(234 88 12); /* Orange-600 */
    --aw-color-secondary: rgb(194 65 12); /* Orange-700 */
    --aw-color-accent: rgb(126 34 206); /* Purple-700 */

    --aw-color-text-heading: rgb(17 24 39);
    --aw-color-text-default: rgb(31 41 55);
    --aw-color-text-muted: rgb(107 114 128);
    --aw-color-bg-page: rgb(249 250 251);

    --aw-color-bg-page-dark: rgb(15 23 42);

    ::selection {
      background-color: rgb(251 146 60 / 30%);
      color: rgb(17 24 39);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Space Grotesk', 'Inter Variable';

    /* Dark mode - brighter oranges and purples */
    --aw-color-primary: rgb(251 146 60); /* Orange-400 */
    --aw-color-secondary: rgb(234 88 12); /* Orange-600 */
    --aw-color-accent: rgb(168 85 247); /* Purple-500 */

    --aw-color-text-heading: rgb(248 250 252);
    --aw-color-text-default: rgb(226 232 240);
    --aw-color-text-muted: rgb(148 163 184);
    --aw-color-bg-page: rgb(15 23 42);

    ::selection {
      background-color: rgb(251 146 60 / 30%);
      color: rgb(248 250 252);
    }
  }
</style>
